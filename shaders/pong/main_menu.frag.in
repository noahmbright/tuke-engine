#version {{ VERSION }}

{{ VERTEX_SHADER common_fullscreen_quad }}

{{ PUSH_CONSTANT }} uniform ShaderToy {
    vec2 res;
    float t;
    vec4 data0;
} st;

{{ LOCATION 0 }} in vec2 uv;
{{ LOCATION 0 }} out vec4 frag_color;

float sphere_sdf(vec3 center, float r, vec3 p) {
    return length(p - center) - r;
}

float rectangle_sdf(vec3 halfs, vec3 p){
    vec3 p_abs = abs(p);
    vec3 diffs = p_abs - halfs;
    vec3 maxs = max(diffs, vec3(0.0));
    return length(maxs);
}

bool intersect_world(vec3 p, out vec3 normal, out vec3 c, out float d) {
    float t2 = st.t * st.t;

    vec3 table_dims = vec3(3.0, 0.25, 5.0);
    float sphere_r = 1.0;

    float ball_y = - 5.0 * pow(abs(sin(5.0 * (1.0 + t2))), 0.9) * exp(-1.5 * t2) - table_dims.y - sphere_r;
    vec3 sphere_pos = vec3(0.0, ball_y, 0.0);
    float d_sphere = sphere_sdf(sphere_pos, sphere_r, p);

    float d_table = rectangle_sdf(table_dims, p);

    d = min(d_sphere, d_table);

    if (d < 0.001) {
        if (d_sphere < d_table) { // Hit sphere
            c = vec3(0.2, 0.1, 1.0);
            normal = (p - sphere_pos) / sphere_r;
        } else { // Hit table
            // Need to move this to the table's coordinate system
            float stripe_width = 0.1;
            float is_stripe = min(abs(p.x) - stripe_width / 2.0,(table_dims.x - abs(p.x) - stripe_width));
            float blend = smoothstep(fwidth(is_stripe), 0.0, is_stripe);
            c = mix(vec3(0.9), vec3(0.1, 0.8, 0.4), blend);
            normal = vec3(0.0, -1.0, 0.0); // TODO
        }
        return true;
    }

    // Miss
    c = vec3(0.0);
    normal = vec3(0.0);
    return false;
}

void main () {
    vec2 iuv = (2 * gl_FragCoord.xy - st.res) / st.res.y;
    vec3 ro = vec3(0.0, -2.0, -5.0);
    vec3 rd = normalize(vec3(iuv, 1.0));
    vec3 lp = vec3(4.0, -10.0, -5.0);
    vec3 lc = vec3(0.6, 0.6, 0.8);

    if (length(iuv - vec2(st.data0)) < st.data0.z) {
        frag_color = vec4(vec3(1.0), 1.0);
        return;
    }

    float t = 0.0;
    vec3 normal;
    vec3 c;
    vec3 p;
    bool hit = false;
    for (uint i = 0; i < 80; i++) {
        p = ro + t * rd;
        float d;
        hit = intersect_world(p, normal, c, d);

        if (hit || d > 100.0) {
            break;
        }

        t += d;
    }

    bool in_shadow = false;
    if (hit) {
        t = 0.0;
        vec3 shadow_ro = p + normal * 0.01;
        vec3 shadow_rd = normalize(lp - p);
        float light_d = length(lp -p);
        vec3 sp, dummy_norm, dummy_c;
        for (uint i = 0; i < 80; i++) {
            sp = shadow_ro + t * shadow_rd;
            float d;
            in_shadow = intersect_world(sp, dummy_norm, dummy_c, d);

            if (in_shadow) {
                break;
            } else if (d > light_d) {
                break;
            }

            t += d;
        }
    }

    if (in_shadow) {
        c *= 0.05;
    } else {
        float d = dot(normal, normalize(lp - p)) * 0.5 + 0.5;
        c *= d * lc;
    }
    frag_color = vec4(pow(c, vec3(1.0/2.2)), 1.0);
}
